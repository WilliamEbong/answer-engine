# ─────────────────────────────────────────────────────────────────────────────
# Personal AI Answer Engine — environment configuration
# Copy to .env and fill in. All values are validated at boot (lib/env.ts);
# the app fails fast with a readable error if anything is missing/malformed.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM (BUILD.md §4) ────────────────────────────────────────────────────────
# One of: anthropic | openai | google | openrouter | openai-compatible
LLM_PROVIDER=anthropic

# Model id as the provider names it, e.g.:
#   anthropic:          claude-sonnet-5, claude-sonnet-4-6
#   openai:             gpt-5.2
#   google:             gemini-3-flash
#   openrouter:         anthropic/claude-sonnet-4.6
#   openai-compatible:  whatever your endpoint serves (e.g. llama3.3:70b)
LLM_MODEL=claude-sonnet-5

# API key for the chosen provider. A dummy value (e.g. "local") is fine for
# local openai-compatible endpoints that don't check auth.
LLM_API_KEY=

# ONLY for LLM_PROVIDER=openai-compatible: the endpoint base URL.
# Leave empty otherwise.
LLM_BASE_URL=

# ── Subscription mode (BUILD.md §5 — optional, config-only) ─────────────────
# Run a community bridge that exposes your Claude Code authenticated session
# as an OpenAI-compatible localhost endpoint (prefer Agent-SDK-based bridges,
# e.g. Meridian, over OAuth-extraction ones), then point the app at it:
#
#   LLM_PROVIDER=openai-compatible
#   LLM_MODEL=<model id the bridge exposes>
#   LLM_API_KEY=local
#   LLM_BASE_URL=http://localhost:<port>/v1
#
# Constraints: localhost only; the Vercel deployment stays on API keys; usage
# draws from your subscription limits; verify Anthropic's current policy
# before using. Nothing in this repo installs or starts a bridge.

# ── Search ───────────────────────────────────────────────────────────────────
# Tavily API key (https://app.tavily.com) — v1 search provider, used
# server-side only via lib/search.ts.
TAVILY_API_KEY=

# ── Database (Supabase, BUILD.md §7) ─────────────────────────────────────────
# Project URL, e.g. https://<project-ref>.supabase.co
SUPABASE_URL=

# SERVICE ROLE key (sb_secret_...) — Dashboard → Project Settings → API keys.
# NOT the publishable (sb_publishable_...) key. Server-side only; never
# exposed to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Postgres connection string for migrations (scripts/migrate.ts).
# Use the SESSION POOLER URI: Dashboard → Connect → Session pooler, port 5432:
#   postgresql://postgres.<ref>:<db-password>@aws-X-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=

# ── Access gate (BUILD.md §2 Auth) ───────────────────────────────────────────
# Password for the /gate page. Leave blank before the build session — it is
# auto-generated and echoed to you at session end.
ACCESS_PASSWORD=

# Secret for HMAC-signing the session cookie (32+ chars). Also auto-generated
# if blank.
COOKIE_SECRET=
